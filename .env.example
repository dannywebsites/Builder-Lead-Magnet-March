# Resend — Email delivery (https://resend.com)
# Create free account, get API key from Dashboard -> API Keys
RESEND_API_KEY=re_your_api_key_here

# Resend Audience ID (optional) — for storing contacts for follow-up marketing
# Create in Resend Dashboard -> Audiences -> Create Audience
RESEND_AUDIENCE_ID=

# Email sender address
# Dev: use "onboarding@resend.dev" (Resend test domain)
# Prod: verify custom domain in Resend Dashboard -> Domains
EMAIL_FROM=Trade Survival Calculator <onboarding@resend.dev>

# GoHighLevel — Webhook URL for lead data sync
# Create in GHL -> Automation -> Workflows -> Webhook trigger
GHL_WEBHOOK_URL=
